<Window x:Class="MapleStoryMacro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MapleMacro" Width="686" Height="655"
        Background="#1E1E23"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"
        KeyDown="MainWindow_KeyDown"
        KeyUp="MainWindow_KeyUp">

    <!-- Styles are in App.xaml Application.Resources -->
    <Window.Resources />

    <!-- ═══════════ Main Layout ═══════════ -->
    <Grid Margin="10,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Top Bar ═══ -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,4">
            <TextBox x:Name="txtWindowTitle" Width="200" Height="32" Text="MapleStory"
                     Style="{StaticResource CyberTextBox}"/>
            <Button x:Name="btnRefreshWindow" Content="重新檢測" Width="90" Height="36" Margin="12,0,0,0"
                    Style="{StaticResource CyberButton}" Background="#253444"
                    Click="BtnRefreshWindow_Click"/>
            <Button x:Name="btnLockWindow" Content="手動鎖定" Width="90" Height="36" Margin="8,0,0,0"
                    Style="{StaticResource CyberButton}" Background="#253444"
                    Click="BtnLockWindow_Click"/>
            <Button x:Name="btnSaveSettings" Content="▼ 導出設定" Width="99" Height="35" Margin="16,0,0,0"
                    Style="{StaticResource CyberButton}" Background="#3C7850"
                    Click="btnSaveSettings_Click"/>
            <Button x:Name="btnImportSettings" Content="▲ 導入設定" Width="99" Height="35" Margin="8,0,0,0"
                    Style="{StaticResource CyberButton}" Background="#465A82"
                    Click="btnImportSettings_Click"/>
        </WrapPanel>

        <!-- ═══ Row 1: Status ═══ -->
        <TextBlock x:Name="lblStatus" Grid.Row="1" Text="狀態: 就緒"
                   Style="{StaticResource StatusLabel}" Foreground="White" Margin="0,2,0,4"/>

        <!-- ═══ Row 2: Log ═══ -->
        <ListBox x:Name="lstLog" Grid.Row="2" Margin="0,2"
                 Style="{StaticResource CyberListBox}"
                 SelectionMode="Extended"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="複製選中" Click="MenuCopyLog_Click"/>
                    <MenuItem Header="清除日誌" Click="MenuClearLog_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <!-- ═══ Row 3: Recording + Script + Settings ═══ -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 錄製控制 -->
            <GroupBox Grid.Column="0" Header="錄製控制" Style="{StaticResource CyberGroupBox}"
                      Width="168" Height="80">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button x:Name="btnStartRecording" Content="▶ 開始" Width="72" Height="35"
                            Style="{StaticResource CyberButton}" Background="#007ACA"
                            Click="BtnStartRecording_Click"/>
                    <Button x:Name="btnStopRecording" Content="■ 停止" Width="72" Height="35" Margin="4,0,0,0"
                            Style="{StaticResource CyberButton}" Background="#C85050" IsEnabled="False"
                            Click="BtnStopRecording_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- 腳本管理 -->
            <GroupBox Grid.Column="1" Header="腳本管理" Style="{StaticResource CyberGroupBox}"
                      Width="235" Height="80" Margin="7,0,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button x:Name="btnSaveScript" Content="保存" Width="65" Height="35"
                            Style="{StaticResource CyberButton}" Background="#3C7850"
                            Click="BtnSaveScript_Click"/>
                    <Button x:Name="btnLoadScript" Content="載入" Width="65" Height="35" Margin="5,0,0,0"
                            Style="{StaticResource CyberButton}" Background="#50648C"
                            Click="BtnLoadScript_Click"/>
                    <Button x:Name="btnEditEvents" Content="編輯" Width="65" Height="35" Margin="5,0,0,0"
                            Style="{StaticResource CyberButton}" Background="#78643C"
                            Click="BtnEditEvents_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- 設定 -->
            <GroupBox Grid.Column="2" Header="設定" Style="{StaticResource CyberGroupBox}"
                      Height="80" Margin="7,0,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button x:Name="btnHotkeySettings" Content="⚙ 熱鍵設定" Width="90" Height="35"
                            Style="{StaticResource CyberButton}" Background="#645078"/>
                    <ComboBox x:Name="cmbArrowMode" Margin="20,0,0,0"
                              Style="{StaticResource CyberComboBox}" Width="100" Height="25">
                        <ComboBoxItem Content="S2C"/>
                        <ComboBoxItem Content="TAB"/>
                        <ComboBoxItem Content="SWB"/>
                    </ComboBox>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- ═══ Row 4: Playback + Advanced ═══ -->
        <Grid Grid.Row="4" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 播放控制 -->
            <GroupBox Grid.Column="0" Header="播放控制" Style="{StaticResource CyberGroupBox}"
                      Width="368" Height="80">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button x:Name="btnStartPlayback" Content="▶ 播放" Width="72" Height="35"
                            Style="{StaticResource CyberButton}" Background="#009650"
                            Click="BtnStartPlayback_Click"/>
                    <Button x:Name="btnStopPlayback" Content="■ 停止" Width="72" Height="35" Margin="4,0,0,0"
                            Style="{StaticResource CyberButton}" Background="#B43C3C" IsEnabled="False"
                            Click="BtnStopPlayback_Click"/>
                    <Button x:Name="txtPauseHotkey" Content="⏸ 暫停" Width="72" Height="35" Margin="4,0,0,0"
                            Style="{StaticResource CyberButton}" Background="#6495ED"
                            Click="BtnPausePlayback_Click"/>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Bottom">
                        <TextBlock x:Name="lblLoopCount" Text="循環次數:" Foreground="White"
                                   FontSize="10" FontFamily="Microsoft JhengHei UI"
                                   HorizontalAlignment="Stretch" TextAlignment="Center"/>
                        <TextBox x:Name="numPlayTimes" Width="68" Height="25" Text="1" Margin="0,3,0,0"
                                 Background="#3C3C41" Foreground="White" BorderBrush="#555"
                                 BorderThickness="1" FontSize="13" TextAlignment="Center"
                                 VerticalContentAlignment="Center" CaretBrush="White"
                                 PreviewTextInput="NumPlayTimes_PreviewTextInput"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- 進階功能 -->
            <GroupBox Grid.Column="1" Header="進階功能" Style="{StaticResource CyberGroupBox}"
                      Height="80" Margin="7,0,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button x:Name="btnMemoryScanner" Content="@ 位置" Width="56" Height="35"
                            Style="{StaticResource CyberButton}" Background="#82503C"/>
                    <Button x:Name="btnCustomKeys" Content="⚡ 自定義" Width="75" Height="35" Margin="4,0,0,0"
                            Style="{StaticResource CyberButton}" Background="#507850"/>
                    <Button x:Name="btnScheduler" Content="⏰ 定時" Width="60" Height="35" Margin="4,0,0,0"
                            Style="{StaticResource CyberButton}" Background="#78643C"/>
                    <Button x:Name="btnStatistics" Content="O 統計" Width="56" Height="35" Margin="4,0,0,0"
                            Style="{StaticResource CyberButton}" Background="#465A82"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- ═══ Row 5: Status Labels ═══ -->
        <StackPanel Grid.Row="5" Margin="0,6,0,2">
            <TextBlock x:Name="lblWindowStatus" Text="視窗: 未鎖定"
                       Style="{StaticResource StatusLabel}" Foreground="Gray"/>
            <TextBlock x:Name="lblRecordingStatus" Text="錄製狀態: 就緒 | 事件數: 0"
                       Style="{StaticResource StatusLabel}" Margin="0,2,0,0"/>
            <TextBlock x:Name="lblPlaybackStatus" Text="播放狀態: 就緒"
                       Style="{StaticResource StatusLabel}" Margin="0,2,0,0"/>
        </StackPanel>
    </Grid>
</Window>
